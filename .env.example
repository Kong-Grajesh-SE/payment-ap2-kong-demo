# Kong - URL of your existing Kong DP proxy
KONG_PROXY_URL=http://localhost:8000

# Konnect API (for schema upload and service config)
KONNECT_CONTROL_PLANE_NAME=<your-cp-name>
KONNECT_CONTROL_PLANE_ID=<your-control-plane-id>
KONNECT_API_TOKEN=<your-konnect-api-token>

# DID Registry
DID_REGISTRY_URL=http://localhost:8070
DID_METHOD=peer
DID_WEB_DOMAIN=localhost:8000

# WORM Storage
WORM_STORAGE_URL=http://localhost:8090
WORM_DB_HOST=worm-db
WORM_DB_PORT=5432
WORM_DB_USER=worm_user
WORM_DB_PASSWORD=worm_secure_password
WORM_DB_NAME=audit_db

# OpenTelemetry
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4318

# ─── Demo UI (Volcano SDK + Mistral) ──────────────────────────────
MISTRAL_API_KEY=<your-mistral-api-key>
MISTRAL_MODEL=mistral-small-latest
DEMO_SERVER_PORT=3001
